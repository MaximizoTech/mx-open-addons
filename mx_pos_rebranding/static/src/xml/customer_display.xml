<templates id="template" xml:space="preserve">

    <!-- Customer display: replace Odoo logo with MaximizoTech custom brand logo -->
    <t t-inherit="point_of_sale.CustomerDisplay" t-inherit-mode="extension">
        
        <!-- Replace the company logo in sidebar with custom brand logo -->
        <xpath expr="//div[hasclass('o_customer_display_logo')]//img" position="replace">
            <img t-if="brandLogo"
                 class="img-fluid"
                 t-att-src="brandLogo"
                 alt="Logo"/>
            <img t-else=""
                 class="img-fluid"
                 t-attf-src="/logo?company={{session.company_id}}"
                 alt="Logo"/>
        </xpath>
        
        <!-- Hide "Powered by Odoo" in sidebar (large screens) - match by text content -->
        <xpath expr="//div[hasclass('position-absolute') and hasclass('bottom-0') and contains(., 'Powered by')]" position="replace">
            <div t-if="false"/>
        </xpath>
        
        <!-- Hide "Powered by Odoo" at bottom of main display - match inner div by text content -->
        <xpath expr="//div[hasclass('d-flex') and hasclass('justify-content-center')]/div[contains(., 'Powered by')]" position="replace">
            <div t-if="false"/>
        </xpath>
        
    </t>

</templates>
